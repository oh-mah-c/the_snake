# =============================================================================
# Target aliases.

build SDL2-static: phony SDL/libSDL2.a

build SDL2main: phony SDL/libSDL2main.a

build libSDL2.a: phony SDL/libSDL2.a

build libSDL2main.a: phony SDL/libSDL2main.a

build sdl_headers_copy: phony SDL/sdl_headers_copy

build snake: phony snake.exe

build uninstall: phony SDL/uninstall

# =============================================================================
# Folder targets.

# =============================================================================

#############################################
# Folder: E:/Github Projects/the_snake/build

build all: phony snake.exe SDL/all

# =============================================================================

#############################################
# Folder: E:/Github Projects/the_snake/build/SDL

build SDL/all: phony SDL/libSDL2main.a SDL/libSDL2.a

