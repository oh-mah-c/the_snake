  OBJECT_DIR = SDL\CMakeFiles\SDL2-static.dir
  POST_BUILD = cd .
  PRE_LINK = cd .
  TARGET_FILE = SDL\libSDL2.a
  TARGET_PDB = SDL2.a.dbg
  RSP_FILE = CMakeFiles\SDL2-static.rsp


#############################################
# Utility command for uninstall

build SDL/uninstall: phony SDL/CMakeFiles/uninstall


#############################################
# Utility command for edit_cache

build SDL/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D "E:\Github Projects\the_snake\build\SDL" && E:\mingw64\bin\cmake.exe -E echo "No interactive CMake dialog available.""
  DESC = No interactive CMake dialog available...
  restat = 1

build SDL/edit_cache: phony SDL/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build SDL/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D "E:\Github Projects\the_snake\build\SDL" && E:\mingw64\bin\cmake.exe --regenerate-during-build -S"E:\Github Projects\the_snake" -B"E:\Github Projects\the_snake\build""
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build SDL/rebuild_cache: phony SDL/CMakeFiles/rebuild_cache.util


